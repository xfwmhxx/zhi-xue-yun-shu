PORT=3000

# 邮件配置（QQ邮箱SMTP - 请替换为你自己的QQ邮箱和授权码）
# 获取QQ邮箱授权码: QQ邮箱 -> 设置 -> 账户 -> POP3/SMTP服务 -> 生成授权码
EMAIL_HOST=smtp.qq.com
EMAIL_PORT=465
EMAIL_USER=your_email@qq.com
EMAIL_PASS=your_email_auth_code


# CORS配置
HTTP_CORS_HOST=*

# DeepSeek API密钥（请替换为你自己的API Key）
# 获取地址: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=your_deepseek_api_key

# AI提供商（可选值: deepseek / spark）
AI_PROVIDER=deepseek

# 讯飞星火大模型配置（仅当 AI_PROVIDER=spark 时需要）
# 获取地址: https://console.xfyun.cn/
SPARK_APPID=your_spark_appid
SPARK_API_KEY=your_spark_api_key
SPARK_API_SECRET=your_spark_api_secret

# 日志配置
LOG_LEVEL=info

# JWT密钥（请替换为随机字符串，用于用户认证token签名）
JWT_SECRET=your-jwt-secret-here-change-me

# 直播麦配置（讯飞语音识别 - 请替换为你自己的凭证）
# 获取地址: https://console.xfyun.cn/
LIVE_MIC_APP_ID=your_live_mic_app_id
LIVE_MIC_APP_KEY=your_live_mic_app_key

# 阿里云配置（用于AI智能体服务 - 请替换为你自己的阿里云AccessKey）
# 获取地址: https://ram.console.aliyun.com/manage/ak
OPENAPI_ACCESS_KEY=your_aliyun_access_key
OPENAPI_ACCESS_SECRET=your_aliyun_access_secret